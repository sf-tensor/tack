{
  "name": "@sf-tensor/tack",
  "version": "0.0.3",
  "description": "Pulumi components for AWS + Kubernetes infrastructure.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.js",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:sf-tensor/tack.git"
  },
  "bugs": {
    "url": "https://github.com/sf-tensor/tack/issues"
  },
  "homepage": "https://github.com/sf-tensor/tack#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "@pulumi/aws": "^7.0.0",
    "@pulumi/cloudflare": "^6.12.0",
    "@pulumi/command": "^1.1.3",
    "@pulumi/eks": "^4.2.0",
    "@pulumi/kubernetes": "^4.24.1",
    "@pulumi/pulumi": "^3.113.0",
    "@pulumi/random": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "@types/node": "^18",
    "typescript": "^5.0.0"
  }
}
